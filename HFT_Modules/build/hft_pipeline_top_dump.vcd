$var wire 32 #Xp a_rdata [31:0] $end
$var wire 9 #Xo b_addr [8:0] $end
$var wire 32 #Y; b_wdata [31:0] $end
$var wire 32 #Y< b_rdata [31:0] $end
$var wire 1 "+ clk $end
$var wire 1 ", rst_n $end
$var wire 1 AX b_wen $end
$upscope $end


$scope module u_index_arb/weight_ram  $end
