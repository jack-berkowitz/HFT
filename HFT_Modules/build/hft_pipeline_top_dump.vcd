$var wire 32 #Y= b_rdata [31:0] $end
$var wire 1 "+ clk $end
$var wire 1 ", rst_n $end
$var wire 1 AY b_wen $end
$upscope $end

$upscope $end

$upscope $end

$enddefinitions $end

